[Unit]
Description=MedFind Daphne — WebSocket Server (WebRTC Signaling)
After=network.target redis.service medfind-gunicorn.service

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/var/www/medfind/backend
EnvironmentFile=/var/www/medfind/.env
ExecStart=/var/www/medfind/venv/bin/daphne \
    -b 127.0.0.1 \
    -p 8001 \
    --access-log /var/log/medfind/daphne-access.log \
    config.asgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
