# ═══════════════════════════════════════════════════════
# MedFind Bangladesh — Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# ═══════════════════════════════════════════════════════

# ── Django Core ──────────────────────────────────────────
DEBUG=False
SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-STRING-50-CHARS-MIN
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── CORS ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Database (PostgreSQL) ────────────────────────────────
DB_NAME=medfind
DB_USER=medfind_user
DB_PASSWORD=CHANGE-THIS-STRONG-PASSWORD
DB_HOST=127.0.0.1
DB_PORT=5432

# ── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_NAME=medfind

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── AWS S3 (file storage) ────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=medfind-files
AWS_S3_REGION_NAME=ap-southeast-1

# ── Anthropic AI ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api...YOUR-KEY-HERE

# ── WebRTC TURN Server ───────────────────────────────────
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_SERVER_USER=medfind
TURN_SERVER_PASS=CHANGE-THIS-TURN-PASSWORD

# ── Payment Gateways (SSLCommerz) ────────────────────────
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASS=your_store_password
# IMPORTANT: Set to False in production!
SSLCOMMERZ_IS_SANDBOX=False

# ── SMS Gateway (for OTP) ────────────────────────────────
SMS_GATEWAY_API_KEY=your-sms-api-key
SMS_SENDER_ID=MedFind

# ── Email ────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── Super Admin Info ──────────────────────────────────────
SUPER_ADMIN_EMAIL=your-admin@email.com
SUPER_ADMIN_BKASH=01XXXXXXXXX
SUPER_ADMIN_NAGAD=01XXXXXXXXX

# ── Seed Data Passwords (DEV only) ───────────────────────
SEED_ADMIN_PASS=CHANGE-THIS-STRONG-PASS
SEED_DOCTOR_PASS=CHANGE-THIS-STRONG-PASS
SEED_PATIENT_PASS=CHANGE-THIS-STRONG-PASS

# ── Medical Field Encryption ───────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=generate-and-put-your-key-here
